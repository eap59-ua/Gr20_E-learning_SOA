	<flow name="put:\courses\(courseId):application\json:CourseService_openapi-config">

    <set-variable variableName="courseId" value="#[attributes.uriParams.courseId]"/>
    <set-variable variableName="rest_key" value="#[attributes.headers.rest_key]"/>

    <!-- BODY COMPLETO EN VARIABLES -->
    <set-variable variableName="title" value="#[payload.title]"/>
    <set-variable variableName="description" value="#[payload.description]"/>
    <set-variable variableName="category" value="#[payload.category]"/>
    <set-variable variableName="durationHours" value="#[payload.durationHours]"/>
    <set-variable variableName="price" value="#[payload.price]"/>
    <set-variable variableName="active" value="#[payload.active]"/>
    <set-variable variableName="legacyContentId" value="#[payload.legacyContentId]"/>

    <flow-ref name="rest_key"/>

    <db:update config-ref="Database_Config">
        <db:sql><![CDATA[
            UPDATE courses
            SET title = :title,
                description = :description,
                category = :category,
                duration_hours = :duration_hours,
                price = :price,
                active = :active,
                external_content_id = :legacy_content_id,
                updated_at = NOW()
            WHERE id = :id
        ]]></db:sql>

        <db:input-parameters><![CDATA[#[{
            id: vars.courseId,
            title: vars.title,
            description: vars.description,
            category: vars.category,
            duration_hours: vars.durationHours,
            price: vars.price,
            active: vars.active,
            legacy_content_id: vars.legacyContentId
        }]]]></db:input-parameters>
    </db:update>

    <ee:transform>
        <ee:message>
            <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  status: "200 OK - CURSO ACTUALIZADO"
}]]></ee:set-payload>
        </ee:message>
    </ee:transform>

</flow>
	<flow name="post:\courses:application\json:CourseService_openapi-config">

