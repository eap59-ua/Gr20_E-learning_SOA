    <set-variable variableName="price" value="#[payload.price]"/>
    <set-variable variableName="currency" value="#[payload.currency default 'EUR']"/>
    <set-variable variableName="legacyContentId" value="#[payload.legacyContentId]"/>

    <!-- VALIDACIÓN REST KEY -->
    <set-variable value="#[payload.instructorId]" doc:name="Set Variable" doc:id="dae0796e-53f1-4fdb-9c78-5eec244eefad" variableName="instructor_id"/>
		<set-variable value="#[payload.instructorName]" doc:name="Set Variable" doc:id="b27b0585-0064-44ec-b818-6e4b8cac82ab" variableName="instructor_name"/>
		<flow-ref name="rest_key"/>

    <!-- INSERT -->
    <db:insert config-ref="Database_Config">
        <db:sql><![CDATA[
            INSERT INTO courses (
                id,
                title,
                description,
                instructor_id,
                instructor_name,
                category,
                duration_hours,
                price,
                currency,
                active,
                created_at,
                external_content_id
            )
            VALUES (
                :id,
                :title,
                :description,
                :instructorId,
                :instructorName,
                :category,
                :durationHours,
                :price,
                :currency,
                :active,
                NOW(),
                :externalContentId
            )
        ]]></db:sql>

        <db:input-parameters><![CDATA[#[{
            id: vars.courseId,
            title: vars.title,
            description: vars.description,
            instructorId: vars.instructor_id,
            instructorName: vars.instructor_name,
            category: vars.category,
            durationHours: vars.durationHours,
            price: vars.price,
            currency: vars.currency,
            active: true,
            externalContentId: vars.legacyContentId
        }]]]></db:input-parameters>
