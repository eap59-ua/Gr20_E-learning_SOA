				<http:request method="DELETE" doc:name="Request" doc:id="0259197e-28c0-4316-ab83-a4b6afae7c6c" config-ref="Gateway_Client_Enrollment" path="/api/v1/enrollments/{enrollmentId}">
					<http:headers ><![CDATA[#[output application/java
---
{
