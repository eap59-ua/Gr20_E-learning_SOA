	}]]]></http:headers>
            </http:response>
        </http:listener>
        <logger level="INFO" doc:name="Logger" doc:id="c652a1e5-0bf6-4d22-a953-6e35b752d1bc" message="#[attributes.headers.rest_key]"/>
		<choice doc:name="Choice" doc:id="2ef5875e-6bcd-44cd-b962-e5a232be0d5c" >
			<when expression='#[attributes.queryParams.id == "enr-create"]'>
				<http:request method="POST" doc:name="Request" doc:id="0aaf0462-7b34-4fa8-b0a5-9e93e06e5bea" config-ref="Gateway_Client_Enrollment" path="/api/v1/enrollments">
