				<http:request method="DELETE" doc:name="Request" doc:id="ba3fc59f-e1cd-4676-b74c-26a7de6e5299" config-ref="Gateway_Client_Enrollment" path="/api/v1/enrollments/{enrollmentId}">
					<http:headers ><![CDATA[#[output application/java
---
{
	rest_key : attributes.headers.rest_key
}]]]></http:headers>
					<http:uri-params ><![CDATA[#[output application/java
---
{
	enrollmentId : vars.uri
}]]]></http:uri-params>
				</http:request>
			</when>
		</choice>
        <error-handler>
            <on-error-continue type="ANY">
                <ee:transform><ee:message><ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{ status: "PROXY_ERROR", target: "EnrollmentService:8083", message: error.description default "?" }]]></ee:set-payload></ee:message></ee:transform>
            </on-error-continue>
        </error-handler>
    </flow>

    <flow name="api-proxy-evaluation-service">
        <http:listener config-ref="API_Gateway_Listener" path="/api/svc/evaluations/*" allowedMethods="GET, POST, PUT, DELETE">
            <http:response statusCode="200">
                <http:headers><![CDATA[#[output application/java
---
{ "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" }]]]></http:headers>
