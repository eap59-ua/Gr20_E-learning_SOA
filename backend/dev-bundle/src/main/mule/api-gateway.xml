<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  API Gateway REST/JSON para el Frontend
  ============================================================================
  Objetivo: exponer una API REST/JSON uniforme con CORS habilitado para que
  el cliente web (frontend) no tenga que lidiar con SOAP envelopes ni con
  problemas de CORS de cada servicio individual.

  Puerto: 8094.

  Endpoints expuestos:
    GET    /api/health                       — ping
    POST   /api/login                        — login (mock)
    GET    /api/courses                      — listado de cursos
    GET    /api/courses/{courseId}           — detalle de curso
    POST   /api/buy-course                   — invoca ESB SOAP de Compra
    GET    /api/certificates/{certificateId} — consulta certificado
    POST   /api/issue-certificate            — invoca ESB REST Emisión
    OPTIONS /api/*                           — CORS preflight

  Todos los responses incluyen las cabeceras CORS necesarias para que el
  navegador acepte las llamadas desde http://localhost:5173 o file://.
  ============================================================================
-->
<mule xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns:http="http://www.mulesoft.org/schema/mule/http"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
http://www.mulesoft.org/schema/mule/http http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd 
http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd http://www.mulesoft.org/schema/mule/core
        http://www.mulesoft.org/schema/mule/core/current/mule.xsd
        http://www.mulesoft.org/schema/mule/ee/core
        http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd
        http://www.mulesoft.org/schema/mule/http
        http://www.mulesoft.org/schema/mule/http/current/mule-http.xsd">

    <http:listener-config name="API_Gateway_Listener">
        <http:listener-connection host="0.0.0.0" port="8094"/>
    </http:listener-config>

    <!-- Cliente HTTP genérico que reutilizamos para invocar a servicios locales -->
    <http:request-config name="Gateway_Client_Course">
        <http:request-connection host="localhost" port="8082"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Cert">
        <http:request-connection host="localhost" port="8087"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_ESB_SOAP">
        <http:request-connection host="localhost" port="8091"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_ESB_REST">
        <http:request-connection host="localhost" port="8092"/>
    </http:request-config>

    <!-- Clientes hacia el resto de servicios del equipo (para el Explorador de Servicios) -->
    <http:request-config name="Gateway_Client_User">
        <http:request-connection host="localhost" port="8081"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Enrollment">
        <http:request-connection host="localhost" port="8083"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Evaluation">
        <http:request-connection host="localhost" port="8084"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Email">
        <http:request-connection host="localhost" port="8085"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Payment">
        <http:request-connection host="localhost" port="8086"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Purchase">
        <http:request-connection host="localhost" port="8088"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_Legacy">
        <http:request-connection host="localhost" port="8089"/>
    </http:request-config>
    <http:request-config name="Gateway_Client_UserProcess">
        <http:request-connection host="localhost" port="8090"/>
    </http:request-config>

    <!--
      ========================================================================
      CORS preflight: responde a TODOS los OPTIONS con 204 y las cabeceras
      necesarias. Sin esto el navegador bloquea las llamadas POST con JSON.
      ========================================================================
    -->
    <flow name="api-cors-preflight">
    <http:listener config-ref="API_Gateway_Listener"
                   path="/api/*"
                   allowedMethods="OPTIONS">

        <http:response statusCode="204">
            <http:headers><![CDATA[#[{
                "Access-Control-Allow-Origin": "*",
                "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type, Authorization, rest_key, WSKey"
            }]]]></http:headers>
        </http:response>

    </http:listener>

    <logger level="INFO" doc:name="Logger" doc:id="2cb20315-d000-4010-936e-b31a3de713e6" message="#[attributes.headers.rest_key]"/>
		<set-payload value="#[payload]"/>
</flow>
    <!--
      ========================================================================
      GET /api/health — health check
      ========================================================================
    -->
    <flow name="api-health">
        <http:listener config-ref="API_Gateway_Listener" path="/api/health" allowedMethods="GET">
            <http:response statusCode="200">
                <http:headers><![CDATA[#[output application/java
---
{ "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" }]]]></http:headers>
            </http:response>
        </http:listener>
        <ee:transform>
            <ee:message>
                <ee:set-payload><![CDATA[%dw 2.0
output application/json
---
{
  status: "ok",
  service: "api-gateway",
  timestamp: now() as String,
  upstreamPorts: {
    mockCourseService:           8082,
    mockEnrollmentService:       8083,
    mockEmailNotification:       8085,
    mockFinancialGateway:        8086,
    certificateService:          8087,
    coursePurchaseProcessService: 8088,
    esbSoapPurchase:             8091,
    esbRestCertificate:          8092
  }
}]]></ee:set-payload>
            </ee:message>
        </ee:transform>
    </flow>

    <!--
      ========================================================================
      POST /api/login — login mock (cualquier usuario/password vale)
      ========================================================================
    -->
