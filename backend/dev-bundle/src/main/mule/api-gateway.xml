			</when>
			<when expression='#[attributes.queryParams.id == "enr-get"]'>
				<set-variable value='#[%dw 2.0&#10;output application/java&#10;---&#10;(attributes.requestPath splitBy "/")[-1]]' doc:name="Set Variable" doc:id="e711bff8-cb76-4c56-843c-8a2b13bb1f68" variableName="uri" />
				<http:request method="GET" doc:name="Request" doc:id="608505e0-5473-41ab-8883-1435d5ef8ece" config-ref="Gateway_Client_Enrollment" path="/api/v1/enrollments/{enrollmentId}">
					<http:headers ><![CDATA[#[output application/java
