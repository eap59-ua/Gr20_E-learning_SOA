---
{ "Content-Type": "application/json", "Access-Control-Allow-Origin": "*" }]]]></http:headers>
            </http:response>
        </http:listener>
        <logger level="INFO" doc:name="Logger" doc:id="de702b47-a0e0-467f-b72d-e007f2cb29fa" message="1"/>
		<http:request method="GET" path="/api/v1/courses" config-ref="Gateway_Client_Course">
			<http:headers ><![CDATA[#[output application/java
---
{
	rest_key : attributes.headers.rest_key
}]]]></http:headers>
		</http:request>
        <error-handler>
            <on-error-continue type="ANY">
